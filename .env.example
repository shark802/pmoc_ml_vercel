# Database Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# Database Host
DB_HOST=srv1322.hstgr.io

# Database User
DB_USER=u520834156_userPmoc

# Database Password (REQUIRED in production)
# Set this to your actual database password
DB_PASSWORD=your_database_password_here

# Database Name
DB_NAME=u520834156_DBpmoc25

# Application Environment
# Options: development, production
ENVIRONMENT=production

# Flask Environment (for Python ML service)
FLASK_ENV=production

# Debug Mode
# Set to true only in development, NEVER in production
DEBUG_MODE=false

# ML Service URL (optional, auto-detected if not set)
# ML_SERVICE_URL=http://127.0.0.1:5000

# Session Configuration
SESSION_LIFETIME=7200

# Security
# Set to true if using HTTPS
HTTPS_ENABLED=true

# API Key (optional, for external API access)
# API_KEY=your_secure_api_key_here
